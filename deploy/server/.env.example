POSTGRES_DB=hypertide
POSTGRES_USER=hypertide
POSTGRES_PASSWORD=hypertide
POSTGRES_PORT=5432
APP_ENV=development
APP_PORT=3000
DB_MAX_CONNECTIONS=10
DB_ACQUIRE_TIMEOUT_SECS=5
AUTH_PEPPER=hypertide-dev-pepper
JWT_ISSUER=hypertide
ACCESS_TOKEN_TTL_SECS=900
REFRESH_TOKEN_TTL_SECS=604800
RATE_LIMIT_REQUESTS_PER_MINUTE=600
WITNESS_CONFIG_JSON={"witnesses":[{"id":"witness-a","secret":"dev-secret-a","scope":"local","environment":"local"},{"id":"witness-b","secret":"dev-secret-b","scope":"local","environment":"local"}],"quorum":1,"scope":"single-env"}
RUST_LOG=hypertide_cli=info,hypertide=info
