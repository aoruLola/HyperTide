APP_ENV=production
RUST_LOG=info,tower_http=info
LOG_FORMAT=json

POSTGRES_DB=hypertide
POSTGRES_USER=hypertide
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_POSTGRES_PASSWORD
DATABASE_URL=postgres://hypertide:CHANGE_ME_LONG_RANDOM_POSTGRES_PASSWORD@postgres:5432/hypertide

MASTER_KEY=CHANGE_ME_32_PLUS_BYTES_RANDOM_MASTER_KEY
AUTH_PEPPER=CHANGE_ME_32_PLUS_BYTES_RANDOM_AUTH_PEPPER
JWT_PRIVATE_KEY_PATH=/app/keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/jwt-public.pem

HIGH_RISK_SIGNATURE_REQUIRED=true
HIGH_RISK_SIGNING_SECRET=CHANGE_ME_32_PLUS_BYTES_RANDOM_HIGH_RISK_SECRET
WITNESS_CONFIG_FILE=/app/keys/witness-config.json

CORS_ALLOWED_ORIGINS=https://hypertide.example.com
RATE_LIMIT_REQUESTS_PER_MINUTE=600
STORAGE_PATH=/app/storage

HYPERTIDE_VERSION=latest
HYPERTIDE_PUBLIC_HOST=hypertide.example.com
